# Copy this file to config.yaml and adjust only the non-secret settings you need.
# Before startup, export OPENROUTER_API_KEY in the shell environment.

# Non-secret application settings for Seahorse.
# Before startup, export OPENROUTER_API_KEY in the shell environment.

provider:
  name: openrouter
  model: google/gemini-3.1-flash-lite-preview
  timeout_seconds: 10.0

logger:
  log_dir: logs
  log_level: debug

storage:
  data_dir: data

mcp:
  enabled_tools:
    - get_user_profile
    - search_memory

vector_memory:
  enabled: true
  retrieval:
    # Controls how many chunks are fetched from the vector store for one search.
    max_chunks: 6
    # Controls how many conversation blocks are returned after chunk deduplication.
    max_blocks: 3
  embedding:
    provider: openai_compatible
    model: qwen3-embedding:4b
    base_url: http://localhost:11434/v1
    # Optional. Set this only if your embedding endpoint requires an API key.
    # Example: OPENAI_API_KEY for OpenAI-compatible remote providers.
    # Leave unset for local Ollama if no key is required.
    # api_key_env: OPENAI_API_KEY
    timeout_seconds: 30.0
  store:
    url: http://localhost:6333
    collection_name: seahorse_memory

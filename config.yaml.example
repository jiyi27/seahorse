# Copy this file to config.yaml and adjust only the non-secret settings you need.
# Before startup, export OPENROUTER_API_KEY in the shell environment.

provider:
  # Supported values: openrouter
  # Default: openrouter
  name: openrouter
  # Required for openrouter.
  model: openai/gpt-4.1-mini
  # Default: 60.0
  timeout_seconds: 60.0

logger:
  # Relative paths are resolved from the project root.
  # Default: logs
  log_dir: logs
  # Supported values: debug, info, warning, error
  # Default: info
  log_level: info

storage:
  # Required. Relative paths are resolved from the project root.
  data_dir: data
  # Required. Relative paths are resolved from the project root.
  persona_dir: personas
  # Required. Loads <persona_dir>/<persona_name>.md
  persona_name: default
